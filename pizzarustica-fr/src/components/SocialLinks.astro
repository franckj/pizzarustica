---
import { social } from '@/data/config';

type IconKey = 'facebook' | 'instagram' | 'tripadvisor' | 'yelp';

const links: {
  href: string;
  label: string;
  icon: IconKey;
  accent: string;
  event: string;
}[] = [
  { href: social.facebook, label: 'Facebook', icon: 'facebook', accent: 'hover:border-blue-500 hover:text-blue-400', event: 'social_click_facebook' },
  { href: social.instagram, label: 'Instagram', icon: 'instagram', accent: 'hover:border-pink-500 hover:text-pink-400', event: 'social_click_instagram' },
  { href: social.tripadvisor, label: 'TripAdvisor', icon: 'tripadvisor', accent: 'hover:border-green-500 hover:text-green-400', event: 'social_click_tripadvisor' },
  { href: social.yelp, label: 'Yelp', icon: 'yelp', accent: 'hover:border-red-500 hover:text-red-400', event: 'social_click_yelp' },
];
---

<section class="bg-stone-950 py-12 px-4 border-t border-stone-900">
  <div class="container-page">
    <h2 class="text-center text-white font-bold text-xl mb-2 font-display">Retrouvez-nous</h2>
    <p class="text-center text-stone-400 text-sm mb-6">Suivez les nouveautés et les photos du four en direct</p>
    <div class="grid grid-cols-2 gap-3 max-w-md mx-auto">
      {links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener"
          class={`flex items-center gap-3 bg-stone-900 rounded-xl p-4 border border-stone-800 text-stone-200 ${link.accent} active:scale-95 transition-all`}
          data-plausible-event-name={link.event}
          aria-label={link.label}>
          <span class="shrink-0" aria-hidden="true">
            {link.icon === 'facebook' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22 12a10 10 0 1 0-11.563 9.876v-6.987H7.898V12h2.539V9.797c0-2.506 1.492-3.89 3.776-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.77-1.63 1.562V12h2.773l-.443 2.889h-2.33v6.987A10.002 10.002 0 0 0 22 12Z" />
              </svg>
            )}
            {link.icon === 'instagram' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z" />
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
              </svg>
            )}
            {link.icon === 'tripadvisor' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 7.5c-2.65 0-5.13.69-7.24 1.9L2 6.5h4.41A11.95 11.95 0 0 1 12 5c2.04 0 3.97.5 5.66 1.38L22 6.5l-2.76 2.9C17.13 8.19 14.65 7.5 12 7.5Zm-5.5 3.25a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Zm0 5.25a1.75 1.75 0 1 1 0-3.5 1.75 1.75 0 0 1 0 3.5Zm11 -5.25a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Zm0 5.25a1.75 1.75 0 1 1 0-3.5 1.75 1.75 0 0 1 0 3.5Z" />
              </svg>
            )}
            {link.icon === 'yelp' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M13.5 2v9.46a.5.5 0 0 0 .82.38l5.62-4.6a.5.5 0 0 0-.07-.82A11.96 11.96 0 0 0 14.18 1.5a.5.5 0 0 0-.68.5Zm0 13.04v6.46a.5.5 0 0 0 .68.47 11.94 11.94 0 0 0 4.7-3.06.5.5 0 0 0-.1-.78l-4.45-2.69a.5.5 0 0 0-.83.27ZM12 13.5a.5.5 0 0 0-.5-.5h-6.5a.5.5 0 0 0-.5.5c0 1.66.34 3.26.95 4.74a.5.5 0 0 0 .75.22l5.6-3.62a.5.5 0 0 0 .2-.34Zm-.7-3.43L6.86 6.13a.5.5 0 0 0-.78.06A11.93 11.93 0 0 0 4.4 10.4a.5.5 0 0 0 .49.6h5.87a.5.5 0 0 0 .43-.74 4.85 4.85 0 0 0-.4-.19Z" />
              </svg>
            )}
          </span>
          <span class="text-sm font-semibold">{link.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>
