---
import { social } from '@/data/config';

const links = [
  { href: social.facebook, label: 'Facebook', icon: '👥', accent: 'hover:border-blue-500', event: 'social_click_facebook' },
  { href: social.instagram, label: 'Instagram', icon: '📸', accent: 'hover:border-pink-500', event: 'social_click_instagram' },
  { href: social.tripadvisor, label: 'TripAdvisor', icon: '🦉', accent: 'hover:border-green-500', event: 'social_click_tripadvisor' },
  { href: social.yelp, label: 'Yelp', icon: '⭐', accent: 'hover:border-red-500', event: 'social_click_yelp' },
];
---

<section class="bg-stone-950 py-12 px-4 border-t border-stone-900">
  <div class="container-page">
    <h2 class="text-center text-white font-bold text-xl mb-2 font-display">Retrouvez-nous</h2>
    <p class="text-center text-stone-400 text-sm mb-6">Suivez les nouveautés et les photos du four en direct</p>
    <div class="grid grid-cols-2 gap-3 max-w-md mx-auto">
      {links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener"
          class={`flex items-center gap-3 bg-stone-900 rounded-xl p-4 border border-stone-800 ${link.accent} active:scale-95 transition-all`}
          data-plausible-event-name={link.event}>
          <span class="text-2xl" aria-hidden="true">{link.icon}</span>
          <span class="text-white text-sm font-semibold">{link.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>
