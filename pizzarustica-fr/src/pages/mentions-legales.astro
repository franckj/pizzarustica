---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { legal, nap, site } from '@/data/config';

const title = `Mentions légales – ${site.name}`;
const description = 'Mentions légales du site pizzarustica.fr — éditeur, hébergement, propriété intellectuelle.';
---

<Base title={title} description={description} canonical={`${site.url}/mentions-legales`} noindex>
  <Header />
  <main id="main" class="pt-24">
    <article class="section">
      <div class="container-page max-w-3xl prose prose-invert prose-stone">
        <h1 class="text-4xl font-black font-display text-white mb-8">Mentions légales</h1>

        <h2>Éditeur du site</h2>
        <p>
          <strong>{legal.legalName}</strong><br />
          Forme juridique : {legal.legalForm}<br />
          Capital social : {legal.capital}<br />
          SIREN : {legal.siren}<br />
          RCS : {legal.rcs}<br />
          Siège social : {legal.headquarters}<br />
          Téléphone : <a href={`tel:${nap.phone}`}>{nap.phoneDisplay}</a><br />
          Email : <a href={`mailto:${nap.email}`}>{nap.email}</a><br />
          Directeur de la publication : {legal.publicationDirector}
        </p>

        <h2>Hébergement</h2>
        <p>
          <strong>{legal.hostName}</strong><br />
          {legal.hostAddress}<br />
          <a href={legal.hostUrl} target="_blank" rel="noopener">{legal.hostUrl}</a>
        </p>

        <h2>Propriété intellectuelle</h2>
        <p>
          L'ensemble des contenus présents sur ce site (textes, images, logos, code) est protégé par
          le droit d'auteur et le droit des marques. Toute reproduction, représentation, modification
          ou exploitation, partielle ou intégrale, sans autorisation écrite préalable est interdite.
        </p>

        <h2>Données personnelles</h2>
        <p>
          Voir notre <a href="/politique-confidentialite">politique de confidentialité</a>.
        </p>

        <h2>Crédits</h2>
        <p>
          Conception et développement : équipe Pizza Rustica.<br />
          Mesure d'audience : Plausible Analytics (sans cookie, conforme RGPD).
        </p>

        <p class="text-stone-500 text-sm mt-12">
          <em>TODO : compléter les champs marqués TODO dans <code>src/data/config.ts</code>.</em>
        </p>
      </div>
    </article>
  </main>
  <Footer />
</Base>

<style>
  .prose h2 {
    @apply text-2xl font-bold text-white mt-10 mb-4 font-display;
  }
  .prose p {
    @apply text-stone-300 leading-relaxed mb-4;
  }
  .prose a {
    @apply text-amber-400 hover:text-amber-300 underline;
  }
</style>
