---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<Base title="Page introuvable – Pizza Rustica" noindex>
  <Header />
  <main id="main" class="pt-24 min-h-[70vh] flex items-center">
    <div class="container-page max-w-xl text-center">
      <p class="text-amber-400 text-6xl font-black font-display mb-4">404</p>
      <h1 class="text-3xl font-bold text-white mb-3">Page introuvable</h1>
      <p class="text-stone-400 mb-8">
        Cette page n'existe pas ou plus. Pas d'inquiétude, la pizza est toujours au four.
      </p>
      <a href="/" class="btn-primary">Retour à l'accueil</a>
    </div>
  </main>
  <Footer />
</Base>
